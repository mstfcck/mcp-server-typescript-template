{
  "name": "mcp-server-typescript-template",
  "version": "0.1.0",
  "description": "A full-featured TypeScript template for building MCP servers",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-server-typescript-template": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:md": "markdownlint-cli2",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run lint:md && npm run test && npm run build",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "generate:tool": "node scripts/generate-tool.mjs",
    "generate:prompt": "node scripts/generate-prompt.mjs",
    "generate:resource": "node scripts/generate-resource.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,js,mjs}": [
      "eslint --fix"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.18.1",
    "prettier": "^3.8.2",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  }
}
